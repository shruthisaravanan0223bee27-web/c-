#include<iostream>
using namespace std;
class mat
{
   private:
      int r,c,m[100][100];
   public:
      mat()
      {
         r=3;c=3;
      }
      void get()
      {
         for(int i=0;i<r;i++)
         {
            for(int j=0;j<c;j++)
            {cin>>m[i][j];
            }}}
      void display()
      {
         cout<<"the matrix"<<endl;
         for(int i=0;i<r;i++){
            for(int j=0;j<c;j++)
            {
               cout<<m[i][j]<<" ";
            }
            cout<<endl;
         }}
      mat add(mat o)
      {
         mat res;
         for(int i=0;i<r;i++)
         {
            for(int j=0;j<c;j++)
            {
               res.m[i][j]=m[i][j]+o.m[i][j];
            }
        }
         return res;
      }
};
int main()
{
   mat m1,m2,m3;
   m1.get();
   m2.get();
   m1.display();
   m2.display();
   m3=m1.add(m2);
   m3.display();
   return 0;
}
