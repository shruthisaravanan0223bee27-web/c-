#include<iostream>
using namespace std;
class generator
{
   protected:
      float v,il,ra;
   public:
      void get()
      {
         cout<<"enter the v,il,ra";
         cin>>v>>il>>ra;
      }
};
class shunt:generator
{
   float rsh;
   public:
   void get1()

   {
      get();
      cout<<"enter rsh"<<endl;
      cin>>rsh;
   }
   void emfsh()
   {
      float ish=v/rsh;
      float e=v+(il+ish)*ra;
      cout<<"e="<<e;
   }
};
class series:generator
{
   float rse;
   public:
   void get2()
   {
      get();
      cout<<"enter rse"<<endl;
      cin>>rse;
   }
   void emfse()
   {
      float e=v+il*(ra+rse);
      cout<<"e="<<e;
   }
};
class lshunt:generator
{
   float rsh,rse;
   public:
   void get3()
   {
      get();
      cout<<"enter rsh,rse"<<endl;
      cin>>rsh>>rse;
   }
   void emfls()
   {
      float ish=v/rsh;
      float e=v+(il+ish)*(ra+rse);
      cout<<"ia="<<(il+ish);
      cout<<"e="<<e;
   }
};
class sshunt:generator
{
   float rse,ia;
   public:
   void get4()
   {
      get();
      cout<<"enter rse,ia"<<endl;
      cin>>rse>>ia;
   }
   void emfss()
   {
      float e=v+ia*(ra+rse);
      cout<<"e="<<e;
   }
};
int main()
{
   shunt x;
   x.get1();
   x.emfsh();
   series y;
   y.get2();
   y.emfse();
   lshunt z;
   z.get3();
   z.emfls();
   sshunt a;
   a.get4();
   a.emfss();
}
